#!/usr/bin/env python3

import subprocess
import sys
import tempfile
import textwrap
from contextlib import contextmanager
from pathlib import Path

REPORTER_NAME = '.ui-test-list-reporter.mjs'


def git(
    *args: str,
    cwd: Path | None = None,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ['git', *args],
        cwd=cwd,
        check=check,
        capture_output=True,
        text=True,
        encoding='utf-8',
        errors='surrogateescape',
    )


def repo_root() -> Path:
    return Path(git('rev-parse', '--show-toplevel').stdout.strip())


def playwright_binary(root: Path) -> Path:
    binary = root / 'node_modules' / '.bin' / 'playwright'
    if binary.is_file():
        return binary

    print(
        'Expected a local Playwright install at node_modules/.bin/playwright. Run npm ci first.',
        file=sys.stderr,
    )
    raise SystemExit(1)


def write_reporter(target_root: Path) -> Path:
    reporter_path = target_root / REPORTER_NAME
    reporter_path.write_text(
        textwrap.dedent(
            '''\
            import path from 'node:path';
            import process from 'node:process';

            function suiteNameFor(test) {
              const describeTitles = [];
              let current = test.parent;
              while (current && current.type !== 'file' && current.type !== 'project' && current.type !== 'root') {
                if (current.type === 'describe' && current.title) {
                  describeTitles.push(current.title);
                }
                current = current.parent;
              }
              describeTitles.reverse();

              const fileName = path.basename(test.location.file);
              const describeTitle = describeTitles.length === 0 ? '(root)' : describeTitles.join(' > ');
              return `${describeTitle} [${fileName}]:`;
            }

            function collectEntries(suite, suiteTests) {
              for (const entry of suite.entries()) {
                if (entry.type === 'test') {
                  suiteTests.push([suiteNameFor(entry), entry.title]);
                  continue;
                }
                collectEntries(entry, suiteTests);
              }
            }

            export default class UiTestListReporter {
              onBegin(_config, suite) {
                const suiteTests = [];
                collectEntries(suite, suiteTests);

                let currentSuite = null;
                for (const [suiteTitle, testTitle] of suiteTests) {
                  if (suiteTitle !== currentSuite) {
                    if (currentSuite !== null) {
                      process.stdout.write('\n');
                    }
                    process.stdout.write(`${suiteTitle}\n`);
                    currentSuite = suiteTitle;
                  }
                  process.stdout.write(`  ${testTitle}\n`);
                }
              }
            }
            '''
        ),
        encoding='utf-8',
    )
    return reporter_path


@contextmanager
def ref_checkout(root: Path, ref: str | None):
    if ref is None:
        yield root
        return

    with tempfile.TemporaryDirectory(prefix='ui-test-list-') as temporary_directory:
        checkout_root = Path(temporary_directory)
        git('worktree', 'add', '--detach', str(checkout_root), ref, cwd=root)
        try:
            node_modules_link = checkout_root / 'node_modules'
            if not node_modules_link.exists():
                node_modules_link.symlink_to(root / 'node_modules', target_is_directory=True)
            yield checkout_root
        finally:
            git('worktree', 'remove', '--force', str(checkout_root), cwd=root)


def suite_test_list(ref: str | None) -> str:
    root = repo_root()
    binary = playwright_binary(root)
    with ref_checkout(root, ref) as target_root:
        reporter_path = write_reporter(target_root)
        try:
            result = subprocess.run(
                [str(binary), 'test', '--list', f'--reporter=./{reporter_path.name}'],
                cwd=target_root,
                check=True,
                capture_output=True,
                text=True,
                encoding='utf-8',
                errors='surrogateescape',
            )
        finally:
            reporter_path.unlink(missing_ok=True)
        return result.stdout


def main() -> int:
    if len(sys.argv) > 2:
        print(f'Usage: {sys.argv[0]} [ref]', file=sys.stderr)
        return 1

    ref = sys.argv[1] if len(sys.argv) == 2 else None
    print(suite_test_list(ref), end='')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
