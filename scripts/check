#!/usr/bin/env bash

set -euo pipefail

with_failed_output() (
  output_file="$(mktemp)"
  trap 'rm -f "$output_file"' EXIT

  should_force_color=0
  if [ -z "${FORCE_COLOR+x}" ] && [ -z "${NO_COLOR+x}" ] && [ -t 1 ]; then
    should_force_color=1
  fi

  status=0
  (
    if [ "$should_force_color" -eq 1 ]; then
      export FORCE_COLOR=1
    fi

    "$@"
  ) >"$output_file" 2>&1 || status=$?

  if [ "$status" -ne 0 ]; then
    cat "$output_file"
  fi

  exit "$status"
)

typechecking_status=0
npm run check:types || typechecking_status=$?

test_status=0
with_failed_output npm test || test_status=$?

[ "$typechecking_status" -eq 0 ] \
  && [ "$test_status" -eq 0 ]
