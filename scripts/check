#!/usr/bin/env bash

set -euo pipefail

if [ -x "./gradlew" ]; then
  echo "Running Gradle check via wrapper..."
  ./gradlew check
  exit 0
fi

required_files=(
  "settings.gradle.kts"
  "build.gradle.kts"
  "app/build.gradle.kts"
  "app/src/main/AndroidManifest.xml"
  "app/src/main/java/com/example/shufflebyalbum/MainActivity.kt"
  "app/src/main/res/layout/activity_main.xml"
)

for file in "${required_files[@]}"; do
  if [ ! -f "$file" ]; then
    echo "Missing required Android project file: $file"
    exit 1
  fi
done

echo "Gradle wrapper not found; Android project structure check passed."
