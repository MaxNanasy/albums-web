#!/usr/bin/env python3

import argparse
import difflib
import subprocess
import sys
from pathlib import Path


def ui_test_list(ref: str, *, cross_platform: bool = False) -> list[str]:
    script = Path(__file__).with_name('ui-test-list')
    command = [sys.executable, str(script)]
    if cross_platform:
        command.append('--cross-platform')
    command.append(ref)
    result = subprocess.run(
        command,
        check=True,
        capture_output=True,
        text=True,
        encoding='utf-8',
        errors='surrogateescape',
    )
    return result.stdout.splitlines(keepends=True)


def build_suite_context(lines: list[str]) -> list[str]:
    contexts: list[str] = []
    current_suite = '(root)'
    for line in lines:
        stripped = line.rstrip('\n')
        if stripped and not stripped.startswith('  '):
            current_suite = stripped
        contexts.append(current_suite)
    return contexts


def format_range_unified(start: int, stop: int) -> str:
    beginning = start + 1
    length = stop - start
    if length == 1:
        return str(beginning)
    if length == 0:
        beginning -= 1
    return f'{beginning},{length}'


def suite_name_for_group(
    group: list[tuple[str, int, int, int, int]],
    base_contexts: list[str],
    head_contexts: list[str],
) -> str:
    for tag, _i1, _i2, j1, j2 in group:
        if tag != 'equal' and j1 < j2:
            return head_contexts[j1]
    for tag, i1, i2, _j1, _j2 in group:
        if tag != 'equal' and i1 < i2:
            return base_contexts[i1]
    return '(root)'


def suite_aware_unified_diff(
    base_lines: list[str],
    head_lines: list[str],
    fromfile: str,
    tofile: str,
    n: int,
) -> list[str]:
    base_contexts = build_suite_context(base_lines)
    head_contexts = build_suite_context(head_lines)
    sequence_matcher = difflib.SequenceMatcher(None, base_lines, head_lines)
    grouped_opcodes = list(sequence_matcher.get_grouped_opcodes(n))
    if not grouped_opcodes:
        return []

    diff_lines = [f'--- {fromfile}\n', f'+++ {tofile}\n']
    for group in grouped_opcodes:
        first, last = group[0], group[-1]
        base_start = first[1]
        base_stop = last[2]
        head_start = first[3]
        head_stop = last[4]
        suite_name = suite_name_for_group(group, base_contexts, head_contexts)
        diff_lines.append(
            f'@@ -{format_range_unified(base_start, base_stop)} '
            f'+{format_range_unified(head_start, head_stop)} @@ {suite_name}\n'
        )
        for tag, i1, i2, j1, j2 in group:
            if tag in ('replace', 'delete'):
                diff_lines.extend(f'-{line}' for line in base_lines[i1:i2])
            if tag in ('replace', 'insert'):
                diff_lines.extend(f'+{line}' for line in head_lines[j1:j2])
            if tag == 'equal':
                diff_lines.extend(f' {line}' for line in base_lines[i1:i2])
    return diff_lines


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description='Show UI test list changes.')
    parser.add_argument('base_ref', help='Base git ref to compare')
    parser.add_argument('head_ref', help='Head git ref to compare')
    parser.add_argument(
        '--cross-platform',
        action='store_true',
        help='Forward --cross-platform to ui-test-list for normalized suite headings',
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    base_lines = ui_test_list(args.base_ref, cross_platform=args.cross_platform)
    head_lines = ui_test_list(args.head_ref, cross_platform=args.cross_platform)

    diff = ''.join(
        suite_aware_unified_diff(
            base_lines,
            head_lines,
            fromfile=f'{args.base_ref} test-list',
            tofile=f'{args.head_ref} test-list',
            n=1,
        )
    )
    if diff.strip():
        print(diff, end='')
    else:
        print('No UI test list changes.')
    return 0


if __name__ == '__main__':
    raise SystemExit(main())
